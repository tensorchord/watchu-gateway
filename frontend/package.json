        "axios": "1.7.7",
        "dayjs": "1.11.11",
        "echarts": "5.5.1",
        "echarts-for-react": "3.0.2",
        "react": "18.3.1",
        "react-dom": "18.3.1",
        "react-router-dom": "6.28.0"
    },
    "devDependencies": {
        "@eslint/js": "9.39.1",
        "@testing-library/jest-dom": "6.6.3",
        "@testing-library/react": "16.1.0",
        "@testing-library/user-event": "14.5.2",
        "@types/node": "22.10.5",
        "@types/react": "18.3.12",
        "@types/react-dom": "18.3.2",
        "@vitejs/plugin-react": "4.3.4",
        "eslint": "9.39.1",
